---
interface Props {
    id?: string;
    className?: string;
    colors?: string[];
}

const {
    id = "particles-container",
    className = "absolute inset-0",
    colors = ["#3498db","#6a89cc","#9b59b6","#ff79a2","#ff5e5b"]
} = Astro.props;
---

<div class={`gradient-background-container ${className}`} data-colors={JSON.stringify(colors)}>
    <div class="gradient-background">
        <div class="sphere-wrapper sphere-1">
            <div class="gradient-sphere"></div>
        </div>
        <div class="sphere-wrapper sphere-2">
            <div class="gradient-sphere"></div>
        </div>
        <div class="sphere-wrapper sphere-3">
            <div class="gradient-sphere"></div>
        </div>
        <div class="sphere-wrapper sphere-4">
            <div class="gradient-sphere"></div>
        </div>
        <div class="sphere-wrapper sphere-5">
            <div class="gradient-sphere"></div>
        </div>
        <div class="glow"></div>
        <div class="grid-overlay"></div>
        <div class="noise-overlay"></div>
        <div class="particles-container" id={id}></div>
    </div>
</div>

<style>
    .gradient-background-container {
        pointer-events: none;
        overflow: hidden;
        z-index: 0;
    }

    .gradient-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #050505;
        overflow: hidden;
    }

    .sphere-wrapper {
        position: absolute;
        will-change: transform;
    }

    .gradient-sphere {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.45;
        will-change: transform;
        transition: transform 0.8s cubic-bezier(0.2, 0, 0.2, 1);
    }

    .sphere-1 {
        width: 45vw;
        height: 45vw;
        top: -10%;
        left: -10%;
        animation: drift-1 35s ease-in-out infinite;
    }
    .sphere-1 .gradient-sphere {
        background: radial-gradient(circle, #ff5e5b 0%, transparent 70%);
    }

    .sphere-2 {
        width: 50vw;
        height: 50vw;
        bottom: -15%;
        right: -15%;
        animation: drift-2 42s ease-in-out infinite;
    }
    .sphere-2 .gradient-sphere {
        background: radial-gradient(circle, #3498db 0%, transparent 70%);
    }

    .sphere-3 {
        width: 38vw;
        height: 38vw;
        top: 35%;
        left: 5%;
        animation: drift-3 38s ease-in-out infinite;
    }
    .sphere-3 .gradient-sphere {
        background: radial-gradient(circle, #9b59b6 0%, transparent 70%);
        opacity: 0.35;
    }

    .sphere-4 {
        width: 32vw;
        height: 32vw;
        top: 15%;
        right: 15%;
        animation: drift-4 45s ease-in-out infinite;
    }
    .sphere-4 .gradient-sphere {
        background: radial-gradient(circle, #ff79a2 0%, transparent 70%);
    }

    .sphere-5 {
        width: 40vw;
        height: 40vw;
        bottom: 5%;
        left: 25%;
        animation: drift-5 50s ease-in-out infinite;
    }
    .sphere-5 .gradient-sphere {
        background: radial-gradient(circle, #6a89cc 0%, transparent 70%);
    }

    @keyframes drift-1 {
        0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
        33% { transform: translate(12%, 8%) rotate(5deg) scale(1.1); }
        66% { transform: translate(-5%, 15%) rotate(-3deg) scale(0.95); }
    }

    @keyframes drift-2 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        40% { transform: translate(-10%, -15%) scale(1.12); }
        75% { transform: translate(5%, -8%) scale(1.05); }
    }

    @keyframes drift-3 {
        0%, 100% { transform: translate(0, 0); opacity: 0.35; }
        50% { transform: translate(15%, -10%) scale(1.1); opacity: 0.5; }
    }

    @keyframes drift-4 {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        30% { transform: translate(8%, 12%) rotate(15deg); }
        70% { transform: translate(-12%, 5%) rotate(-5deg); }
    }

    @keyframes drift-5 {
        0%, 100% { transform: translate(0, 0) scale(1); }
        45% { transform: translate(10%, -12%) scale(1.08); }
        80% { transform: translate(-8%, -5%) scale(0.95); }
    }

    .noise-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.05;
        z-index: 5;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }

    .grid-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-size: 40px 40px;
        background-image: 
            linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        z-index: 2;
    }

    .glow {
        position: absolute;
        width: 40vw;
        height: 40vh;
        background: radial-gradient(circle, rgba(52, 152, 219, 0.1), transparent 70%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 2;
        animation: pulse 12s infinite alternate;
        filter: blur(50px);
    }

    @keyframes pulse {
        0% { opacity: 0.2; transform: translate(-50%, -50%) scale(0.85); }
        100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1.15); }
    }

    .particles-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 3;
        pointer-events: none;
    }

    :global(.particle) {
        position: absolute;
        background: white;
        border-radius: 50%;
        opacity: 0;
        pointer-events: none;
    }
</style>

<script>
    class ParticleAnimation {
        container: HTMLElement;
        particleCount: number;
        colors: string[];

        constructor(containerId: string, colors: string[]) {
            this.container = document.getElementById(containerId) as HTMLElement;
            this.particleCount = 60; // Slightly reduced for performance
            this.colors = colors;
            if (this.container) {
                this.init();
            }
        }

        init() {
            // Create particles
            for (let i = 0; i < this.particleCount; i++) {
                this.createParticle();
            }

            // Mouse interaction
            document.addEventListener('mousemove', (e) => this.handleMouseMove(e));
        }

        createParticle() {
            const particle = document.createElement('div');
            particle.className = 'particle';
            
            const size = Math.random() * 2 + 1;
            particle.style.width = `${size}px`;
            particle.style.height = `${size}px`;
            
            if (Math.random() > 0.6) {
                particle.style.background = this.colors[Math.floor(Math.random() * this.colors.length)];
            } else {
                particle.style.background = 'white';
            }
            
            const pos = this.resetParticle(particle);
            this.container.appendChild(particle);
            this.animateParticle(particle, pos);
        }

        resetParticle(particle: HTMLElement) {
            const posX = Math.random() * 100;
            const posY = Math.random() * 100;
            
            particle.style.left = `${posX}%`;
            particle.style.top = `${posY}%`;
            particle.style.opacity = '0';
            
            return { x: posX, y: posY };
        }

        animateParticle(particle: HTMLElement, initialPos: { x: number, y: number }) {
            const duration = Math.random() * 15 + 15;
            const delay = Math.random() * 5;
            
            setTimeout(() => {
                if (!particle.parentElement) return;
                
                particle.style.transition = `all ${duration}s linear`;
                particle.style.opacity = (Math.random() * 0.2 + 0.05).toString();
                
                const moveX = initialPos.x + (Math.random() * 15 - 7.5);
                const moveY = initialPos.y - Math.random() * 20;
                
                particle.style.left = `${moveX}%`;
                particle.style.top = `${moveY}%`;
                
                setTimeout(() => {
                    if (!particle.parentElement) return;
                    const newPos = this.resetParticle(particle);
                    this.animateParticle(particle, newPos);
                }, duration * 1000);
            }, delay * 1000);
        }

        handleMouseMove(e: MouseEvent) {
            const mouseX = (e.clientX / window.innerWidth) * 100;
            const mouseY = (e.clientY / window.innerHeight) * 100;
            
            // Create temporary trail particle
            if (Math.random() > 0.8) {
                this.createTrailParticle(mouseX, mouseY);
            }
            
            // Organic parallax for spheres
            const spheres = document.querySelectorAll('.gradient-sphere');
            
            spheres.forEach((sphere, index) => {
                if (sphere instanceof HTMLElement) {
                    const factor = (index + 1) * 15;
                    const moveX = (e.clientX / window.innerWidth - 0.5) * factor;
                    const moveY = (e.clientY / window.innerHeight - 0.5) * factor;
                    
                    sphere.style.transform = `translate(${moveX}px, ${moveY}px)`;
                }
            });
        }

        createTrailParticle(x: number, y: number) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            
            const size = Math.random() * 3 + 2;
            particle.style.width = `${size}px`;
            particle.style.height = `${size}px`;
            particle.style.background = this.colors[Math.floor(Math.random() * this.colors.length)];
            
            particle.style.left = `${x}%`;
            particle.style.top = `${y}%`;
            particle.style.opacity = '0.4';
            
            this.container.appendChild(particle);
            
            setTimeout(() => {
                particle.style.transition = 'all 2.5s ease-out';
                particle.style.transform = `translate(${(Math.random() - 0.5) * 40}px, ${(Math.random() - 0.5) * 40}px)`;
                particle.style.opacity = '0';
                
                setTimeout(() => {
                    particle.remove();
                }, 2500);
            }, 20);
        }
    }

    // Initialize on page load
    document.addEventListener('astro:page-load', () => {
        initParticles();
    });

    // Fallback for non-view-transition navigation
    if (document.readyState === 'complete') {
        initParticles();
    } else {
        window.addEventListener('load', initParticles);
    }

    function initParticles() {
        const containers = document.querySelectorAll('.particles-container');
        containers.forEach(container => {
            if (container instanceof HTMLElement && container.id && !container.hasAttribute('data-initialized')) {
                const parent = container.closest('[data-colors]');
                const colors = parent ? JSON.parse(parent.getAttribute('data-colors') || '[]') : [];
                new ParticleAnimation(container.id, colors);
                container.setAttribute('data-initialized', 'true');
            }
        });
    }
</script>

