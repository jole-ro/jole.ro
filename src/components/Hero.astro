---
const { lang = "en" } = Astro.props;
import ParticlesBackground from "./ParticlesBackground.astro";

const content = {
  en: {
    title: "Dominate the European Market with an Elite Digital Presence",
    subtitle:
      "Multilanguage SEO and premium web strategies designed to transform your brand into an undisputed leader across Europe.",
    location: "🇪🇺 European Expertise. Global Standards. Local Results.",
    description:
      "Position your business at the highest level. We provide digital solutions that combine high-end technical refinement with a deep understanding of European local cultures.",
    checks: [
      "Elite SEO strategies for European expansion",
      "Premium local trust signals and authority",
      "High-end business presentation websites",
      "Maximum visibility in the AI and SGE era",
    ],
    highlight:
      "💡 Lead the European market with a digital presence that feels local in every country, but powerful across the continent.",
    cta: "Start Your Journey",
    audit: "Get Free SEO Audit",
    auditLink: "/seo-audit",
  },
  hu: {
    title: "Uralja az európai piacot elit digitális jelenléttel",
    subtitle:
      "Többnyelvű SEO és prémium webes stratégiák, amelyek célja, hogy márkáját az egész kontinensen vitathatatlan vezetővé tegyék.",
    location: "🇪🇺 Európai szakértelem. Globális szabványok. Helyi eredmények.",
    description:
      "Pozícionálja vállalkozását a legmagasabb szintre. Olyan digitális megoldásokat kínálunk, amelyek ötvözik a kifinomult technikai optimalizálást a helyi kultúrák mély ismeretével.",
    checks: [
      "Elit SEO stratégiák az európai terjeszkedéshez",
      "Prémium helyi bizalmi jelek és tekintélyépítés",
      "Csúcskategóriás üzleti bemutatkozó weboldalak",
      "Maximális láthatóság az AI és SGE korszakában",
    ],
    highlight:
      "💡 Vezesse az európai piacot olyan digitális jelenléttel, amely minden országban helyinek hat, de az egész kontinensen erős!",
    cta: "Kezdje el most",
    audit: "Ingyenes SEO Audit",
    auditLink: "/hu/ingyenes-seo-audit",
  },
  ro: {
    title: "Domină Piața Europeană cu o Prezență Digitală de Elită",
    subtitle:
      "SEO multilingv și strategii web premium, concepute pentru a transforma brandul tău într-un lider incontestabil pe întreg continentul.",
    location: "🇪🇺 Expertiză Europeană. Standarde Globale. Rezultate Locale.",
    description:
      "Poziționează-ți afacerea la cel mai înalt nivel. Oferim soluții digitale ce îmbină rafinamentul tehnic de top cu o înțelegere profundă a culturilor locale europene.",
    checks: [
      "Strategii SEO de elită pentru expansiune europeană",
      "Semnale de încredere și autoritate locală premium",
      "Website-uri de prezentare business high-end",
      "Vizibilitate maximă în era AI și Search Generative Experience",
    ],
    highlight:
      "💡 Fii lider pe piața europeană cu o prezență digitală care se simte locală în fiecare țară, dar este puternică pe tot continentul.",
    cta: "Începe acum",
    audit: "Audit SEO Gratuit",
    auditLink: "/ro/audit-seo-gratuit",
  },
};

const t = content[lang as keyof typeof content] || content.en;
---

<section
  class="relative min-h-[80vh] flex items-center overflow-hidden"
  id="hero-section"
>
  <ParticlesBackground />
  <div class="absolute inset-0 pointer-events-none"></div>
  <div
    class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 my-24 bg-white backdrop-blur-sm border border-gray-200 rounded-3xl shadow-xl"
  >
    <div class="max-w-2xl mt-8 mb-8 pointer-events-auto">
      <h1
        class="text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary to-pink-500 mb-6 leading-tight"
      >
        {t.title}
      </h1>
      <p class="text-xl text-gray-600 mb-4">{t.subtitle}</p>
      <p class="text-xl text-gray-600 mb-4">{t.location}</p>
      <p class="text-xl text-gray-600 mb-8">{t.description}</p>
      <div class="space-y-3 mb-8">
        {
          t.checks.map((check) => (
            <p class="text-lg text-gray-600 flex items-start">
              <i class="ri-checkbox-circle-fill icon-gradient mr-2 text-xl" />
              <span>{check}</span>
            </p>
          ))
        }
      </div>
      <p class="text-xl text-gray-600 mb-8">{t.highlight}</p>
      <div class="flex flex-wrap gap-4">
        <a
          href={lang === "en" ? "/contact" : `/${lang}/contact`}
          class="inline-block bg-primary text-white px-10 py-4 rounded-xl text-lg font-semibold hover:bg-primary-hover cursor-pointer whitespace-nowrap transition-all shadow-lg shadow-primary/20 hover:-translate-y-1 active:scale-95"
        >
          {t.cta}
        </a>
        <a
          href={t.auditLink}
          class="inline-block bg-white text-primary border-2 border-primary px-10 py-4 rounded-xl text-lg font-semibold hover:bg-gray-50 cursor-pointer whitespace-nowrap transition-all shadow-lg shadow-gray-200/50 hover:-translate-y-1 active:scale-95"
        >
          {t.audit}
        </a>
      </div>
    </div>
  </div>
</section>
